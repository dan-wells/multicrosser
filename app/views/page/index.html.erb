<% series_config = Series::SERIES %>
<% latest_by_series = @series_with_crosswords.to_h { |name, crosswords| [name, crosswords.first&.identifier] } %>
<div class="homepage">
  <div class="homepage-sidebar">
    <h3>Go to puzzle</h3>
    <form onsubmit="return goToPuzzle(this)">
      <label for="goto-series">Series</label>
      <select id="goto-series" name="series" onchange="updatePuzzlePlaceholder()">
        <%- series_config.each do |name, meta| -%>
          <option value="<%= name %>"
                  data-first-puzzle="<%= meta[:first_puzzle] %>"
                  data-latest-puzzle="<%= latest_by_series[name] %>"
                  data-skip-period="<%= meta[:skip_period] %>"
                  data-skip-ref="<%= meta[:skip_ref] %>"><%= name.titleize %></option>
        <%- end -%>
      </select>

      <label for="goto-number">Puzzle</label>
      <input type="text" id="goto-number" name="number" autocomplete="off" list="puzzle-suggestions">
      <datalist id="puzzle-suggestions"></datalist>
      <div id="goto-error" class="form-error"></div>

      <label for="goto-room">Room</label>
      <input type="text" id="goto-room" name="room" placeholder="e.g. my-room" autocomplete="off" list="room-suggestions">
      <datalist id="room-suggestions"></datalist>

      <div class="goto-buttons">
        <button type="submit">Go</button>
        <button type="button" class="random" onclick="return goToRandomPuzzle(this.form)">Random</button>
      </div>
      <p>
        If <strong>puzzle</strong> is empty, go to the most recent in the series.
        <br>
        If <strong>room</strong> is empty, go to a random room number.
        <br>
        Hit <strong>random</strong> to go to a random puzzle in the series.
      </p>
    </form>
  </div>

  <div class="homepage-main">
    <p class="intro">
      Pick one of the crosswords below then share the link with friends to solve together.
    </p>

    <%- @series_with_crosswords.each do |series, crosswords| -%>
      <h3><%= series.titleize %></h3>
      <ul>
      <%- crosswords.each do |crossword| -%>
        <li>
          <%= link_to(crossword.name, crossword_path(crossword.series, crossword.identifier)) %>
        </li>
      <%- end -%>
      </ul>
    <%- end -%>

    <p class="about">
      <strong>Several People are Solving</strong> is an experiment with multiplayer crosswords created by <a href="https://chriszetter.com">Chris Zetter</a>. You can <a href="https://github.com/zetter/multicrosser">view the code on GitHub</a>.
    </p>
  </div>
</div>

<script>
  function updatePuzzlePlaceholder() {
    var select = document.getElementById('goto-series');
    var option = select.options[select.selectedIndex];
    var first = option.getAttribute('data-first-puzzle');
    document.getElementById('goto-number').placeholder = first + ' onwards';
  }
  updatePuzzlePlaceholder();

  var links = Array.from(document.querySelectorAll('.homepage-main a'));
  var originalHrefs = links.map(function(a) { return a.href; });

  function populatePuzzleDatalist() {
    var series   = document.getElementById('goto-series').value;
    var puzzles  = JSON.parse(localStorage.getItem('previous-puzzles-' + series) || '[]');
    var datalist = document.getElementById('puzzle-suggestions');
    datalist.innerHTML = '';
    puzzles.forEach(function(num) {
      var opt = document.createElement('option');
      opt.value = num;
      datalist.appendChild(opt);
    });
  }
  document.getElementById('goto-series').addEventListener('change', populatePuzzleDatalist);

  function rewriteLinks() {
    var room = document.getElementById('goto-room').value.trim();
    links.forEach(function(a, i) {
      a.href = room ? originalHrefs[i] + '/' + encodeURIComponent(room) : originalHrefs[i];
    });
  }
  document.getElementById('goto-room').addEventListener('input', rewriteLinks);

  function initFromStorage() {
    var lastRoom   = localStorage.getItem('last-room');
    var lastSeries = localStorage.getItem('last-series');
    var lastPuzzle = localStorage.getItem('last-puzzle');
    var rooms      = JSON.parse(localStorage.getItem('previous-rooms') || '[]');

    if (lastRoom)   document.getElementById('goto-room').value   = lastRoom;
    if (lastPuzzle) document.getElementById('goto-number').value = lastPuzzle;
    if (lastSeries) {
      var sel = document.getElementById('goto-series');
      for (var i = 0; i < sel.options.length; i++) {
        if (sel.options[i].value === lastSeries) { sel.selectedIndex = i; break; }
      }
      updatePuzzlePlaceholder();
    }

    var roomDatalist = document.getElementById('room-suggestions');
    roomDatalist.innerHTML = '';
    rooms.forEach(function(name) {
      var opt = document.createElement('option');
      opt.value = name;
      roomDatalist.appendChild(opt);
    });

    populatePuzzleDatalist();
    rewriteLinks();
  }
  window.addEventListener('pageshow', initFromStorage);

  function goToPuzzle(form) {
    var series = form.series.value;
    var number = form.number.value.trim();
    var room = form.room.value.trim();
    var errorEl = document.getElementById('goto-error');
    var option = form.series.options[form.series.selectedIndex];

    if (!number) {
      var latest = option.getAttribute('data-latest-puzzle');
      if (!latest) {
        errorEl.textContent = 'No puzzles available for ' + series.charAt(0).toUpperCase() + series.slice(1);
        return false;
      }
      number = latest;
    } else {
      var firstPuzzle = parseInt(option.getAttribute('data-first-puzzle'), 10);
      var num = parseInt(number, 10);
      if (isNaN(num) || num < firstPuzzle) {
        errorEl.textContent = series.charAt(0).toUpperCase() + series.slice(1) + ' puzzles start at No ' + firstPuzzle;
        return false;
      }
    }

    errorEl.textContent = '';
    var pathPrefix = '<%= Rails.application.config.relative_url_root.to_s %>';
    var url = pathPrefix + '/' + encodeURIComponent(series) + '/' + encodeURIComponent(number);
    if (room) url += '/' + encodeURIComponent(room);
    window.location = url;
    return false;
  }

  function goToRandomPuzzle(form) {
    var series = form.series.value;
    var room = form.room.value.trim();
    var errorEl = document.getElementById('goto-error');
    var option = form.series.options[form.series.selectedIndex];
    var first = parseInt(option.getAttribute('data-first-puzzle'), 10);
    var latest = parseInt(option.getAttribute('data-latest-puzzle'), 10);

    if (!latest) {
      errorEl.textContent = 'No puzzles available for ' + series.charAt(0).toUpperCase() + series.slice(1);
      return false;
    }

    var skipPeriod = parseInt(option.getAttribute('data-skip-period'), 10);
    var skipRef    = parseInt(option.getAttribute('data-skip-ref'),    10);

    var number;
    do {
      number = Math.floor(Math.random() * (latest - first + 1)) + first;
    } while (skipPeriod && skipRef &&
             ((number - skipRef) % skipPeriod + skipPeriod) % skipPeriod === skipPeriod - 1);
    errorEl.textContent = '';
    var pathPrefix = '<%= Rails.application.config.relative_url_root.to_s %>';
    var url = pathPrefix + '/' + encodeURIComponent(series) + '/' + encodeURIComponent(number);
    if (room) url += '/' + encodeURIComponent(room);
    window.location = url;
    return false;
  }
</script>
