<h1><%= @parsed_crossword['name'] %></h1>
<p>
  <%= Time.at(@parsed_crossword['date']/1000).to_date.strftime("%a %-d %b %Y") %> |
  <%- if @parsed_crossword['creator'] -%>
    Set by <%= link_to @parsed_crossword['creator']['name'], @parsed_crossword['creator']['webUrl'] %> |
  <%- end -%>
  <%= link_to "Fifteensquared", @fifteensquared_url %>
</p>

<%= content_tag(:div, '', class: 'js-crossword', data: {
  crossword: @crossword,
  'crossword-identifier': crossword_identifier,
  room: params[:room],
}) %>

<%= stylesheet_pack_tag "application" %>
<%= javascript_pack_tag "application", "data-turbolinks-track": "reload" %>

<p style="clear: both;">
  Share this page with others to solve this crossword with them.
  <br><a href="<%= @url %>">Published by the Guardian</a>
</p>
