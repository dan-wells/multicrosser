<div class="not-found">
  <h1>Puzzle not found</h1>
  <p>
    Sorry, we couldn't find
    <% if @series && @identifier %>
      <strong><%= Series.display_name(@series) %> crossword No <%= @identifier %></strong>.
    <% else %>
      that puzzle.
    <% end %>
  </p>
  <p>The puzzle may not exist, or it may not be available from the publisher.</p>
  <p><a href="/">Back to the homepage</a></p>
</div>
