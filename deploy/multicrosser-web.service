# Place at: /etc/systemd/system/multicrosser-web.service
[Unit]
Description=Multicrosser Rails app
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/multicrosser
EnvironmentFile=/var/www/multicrosser/.env.production
ExecStart=/root/miniconda3/envs/multicrosser/share/rubygems/bin/bundle exec puma -C config/puma.rb
Restart=on-failure

[Install]
WantedBy=multi-user.target
